<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="qbot2_robot">

  <!-- ==================== PROPERTIES ==================== -->
  <!-- Chassis (QBot2-style: cylindrical body) -->
  <xacro:property name="chassis_radius" value="0.17"/>
  <xacro:property name="chassis_height" value="0.09"/>
  <xacro:property name="chassis_mass" value="4.0"/>

  <!-- Drive wheels -->
  <xacro:property name="wheel_radius" value="0.035"/>
  <xacro:property name="wheel_width" value="0.025"/>
  <xacro:property name="wheel_mass" value="0.3"/>
  <xacro:property name="wheel_separation" value="0.23"/>

  <!-- Caster wheel -->
  <xacro:property name="caster_radius" value="0.015"/>
  <xacro:property name="caster_mass" value="0.1"/>

  <!-- Kinect V2 sensor -->
  <xacro:property name="kinect_width" value="0.25"/>
  <xacro:property name="kinect_height" value="0.07"/>
  <xacro:property name="kinect_depth" value="0.06"/>
  <xacro:property name="kinect_mass" value="0.5"/>
  <xacro:property name="kinect_mount_height" value="0.30"/>

  <!-- ==================== MATERIALS ==================== -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>

  <!-- ==================== MACROS ==================== -->
  <!-- Inertia for a solid cylinder (rotation about Z-axis) -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(1.0/12.0)*m*(3*r*r + h*h)}" ixy="0" ixz="0"
               iyy="${(1.0/12.0)*m*(3*r*r + h*h)}" iyz="0"
               izz="${(1.0/2.0)*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- Inertia for a solid sphere -->
  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(2.0/5.0)*m*r*r}" ixy="0" ixz="0"
               iyy="${(2.0/5.0)*m*r*r}" iyz="0"
               izz="${(2.0/5.0)*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- Inertia for a solid box -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(1.0/12.0)*m*(y*y + z*z)}" ixy="0" ixz="0"
               iyy="${(1.0/12.0)*m*(x*x + z*z)}" iyz="0"
               izz="${(1.0/12.0)*m*(x*x + y*y)}"/>
    </inertial>
  </xacro:macro>

  <!-- ==================== BASE FOOTPRINT ==================== -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius + 0.005}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== BASE LINK (Chassis) ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="${chassis_radius}" length="${chassis_height}"/>
      </geometry>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${chassis_radius}" length="${chassis_height}"/>
      </geometry>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="${chassis_mass}"/>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <inertia ixx="${(1.0/12.0)*chassis_mass*(3*chassis_radius*chassis_radius + chassis_height*chassis_height)}" ixy="0" ixz="0"
               iyy="${(1.0/12.0)*chassis_mass*(3*chassis_radius*chassis_radius + chassis_height*chassis_height)}" iyz="0"
               izz="${(1.0/2.0)*chassis_mass*chassis_radius*chassis_radius}"/>
    </inertial>
  </link>

  <!-- ==================== SECOND DECK (top platform) ==================== -->
  <link name="plate_top_link">
    <visual>
      <geometry>
        <cylinder radius="${chassis_radius - 0.01}" length="0.006"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${chassis_radius - 0.01}" length="0.006"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="plate_top_joint" type="fixed">
    <parent link="base_link"/>
    <child link="plate_top_link"/>
    <origin xyz="0 0 ${chassis_height + 0.05}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== STANDOFFS (4 pillars) ==================== -->
  <xacro:macro name="standoff" params="name x y">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="0.006" length="0.05"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="0.006" length="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.02"/>
        <inertia ixx="0.0001" ixy="0" ixz="0"
                 iyy="0.0001" iyz="0"
                 izz="0.0001"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} ${chassis_height + 0.025}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:standoff name="standoff_front_left"  x="0.08"  y="0.08"/>
  <xacro:standoff name="standoff_front_right" x="0.08"  y="-0.08"/>
  <xacro:standoff name="standoff_rear_left"   x="-0.08" y="0.08"/>
  <xacro:standoff name="standoff_rear_right"  x="-0.08" y="-0.08"/>

  <!-- ==================== DRIVE WHEELS ==================== -->
  <xacro:macro name="drive_wheel" params="prefix y_reflect">
    <link name="${prefix}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel"/>
      <origin xyz="0 ${y_reflect * wheel_separation / 2} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.01" friction="0.1"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel prefix="left"  y_reflect="1"/>
  <xacro:drive_wheel prefix="right" y_reflect="-1"/>

  <!-- ==================== CASTER WHEELS ==================== -->
  <xacro:macro name="caster_wheel" params="name x_offset">
    <link name="${name}">
      <visual>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="white"/>
      </visual>
      <collision name="${name}_collision">
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
      <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}"/>
    </link>

    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${x_offset} 0 ${-(wheel_radius - caster_radius) + 0.002}" rpy="0 0 0"/>
    </joint>

    <!-- Frictionless surface for casters in Gazebo Harmonic -->
    <gazebo reference="${name}_collision">
      <surface>
        <friction>
          <ode>
            <mu>0.001</mu>
            <mu2>0.001</mu2>
          </ode>
        </friction>
      </surface>
    </gazebo>
  </xacro:macro>

  <xacro:caster_wheel name="front_caster" x_offset="0.12"/>
  <xacro:caster_wheel name="rear_caster"  x_offset="-0.12"/>

  <!-- ==================== KINECT V2 SENSOR MOUNT ==================== -->
  <!-- Sensor pole / neck -->
  <link name="camera_mount_link">
    <visual>
      <geometry>
        <cylinder radius="0.015" length="${kinect_mount_height - chassis_height}"/>
      </geometry>
      <origin xyz="0 0 ${(kinect_mount_height - chassis_height)/2}" rpy="0 0 0"/>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.015" length="${kinect_mount_height - chassis_height}"/>
      </geometry>
      <origin xyz="0 0 ${(kinect_mount_height - chassis_height)/2}" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 ${(kinect_mount_height - chassis_height)/2}" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_mount_link"/>
    <origin xyz="-0.02 0 ${chassis_height}" rpy="0 0 0"/>
  </joint>

  <!-- Kinect V2 body -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="${kinect_depth} ${kinect_width} ${kinect_height}"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="${kinect_depth} ${kinect_width} ${kinect_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${kinect_mass}" x="${kinect_depth}" y="${kinect_width}" z="${kinect_height}"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="camera_mount_link"/>
    <child link="camera_link"/>
    <origin xyz="0.02 0 ${kinect_mount_height - chassis_height}" rpy="0 0 0"/>
  </joint>

  <!-- Kinect V2 optical frame (Z forward, X right, Y down) -->
  <link name="camera_depth_optical_frame"/>

  <joint name="camera_depth_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ==================== GAZEBO COLORS ==================== -->
  <gazebo reference="base_link">
    <material>
      <ambient>0.2 0.2 0.2 1</ambient>
      <diffuse>0.2 0.2 0.2 1</diffuse>
    </material>
  </gazebo>
  <gazebo reference="plate_top_link">
    <material>
      <ambient>0.9 0.9 0.9 1</ambient>
      <diffuse>0.9 0.9 0.9 1</diffuse>
    </material>
  </gazebo>
  <gazebo reference="left_wheel">
    <material>
      <ambient>0.05 0.05 0.05 1</ambient>
      <diffuse>0.05 0.05 0.05 1</diffuse>
    </material>
  </gazebo>
  <gazebo reference="right_wheel">
    <material>
      <ambient>0.05 0.05 0.05 1</ambient>
      <diffuse>0.05 0.05 0.05 1</diffuse>
    </material>
  </gazebo>
  <gazebo reference="camera_link">
    <material>
      <ambient>0.05 0.05 0.05 1</ambient>
      <diffuse>0.05 0.05 0.05 1</diffuse>
    </material>
  </gazebo>
  <gazebo reference="camera_mount_link">
    <material>
      <ambient>0.2 0.2 0.2 1</ambient>
      <diffuse>0.2 0.2 0.2 1</diffuse>
    </material>
  </gazebo>

  <!-- ==================== GAZEBO: DIFFERENTIAL DRIVE PLUGIN ==================== -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <!-- Wheel joints -->
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <!-- Kinematics -->
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>

      <!-- Limits -->
      <max_linear_acceleration>1.0</max_linear_acceleration>

      <!-- Output -->
      <odom_publish_frequency>30</odom_publish_frequency>

      <!-- Use default model-scoped topics:
           cmd_vel: /model/qbot2_robot/cmd_vel
           odom:    /model/qbot2_robot/odometry
           tf:      /model/qbot2_robot/tf
           These are mapped to flat ROS topics via gz_bridge.yaml -->

      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>

  <!-- ==================== GAZEBO: KINECT V2 DEPTH CAMERA (RGBD) ==================== -->
  <gazebo reference="camera_link">
    <!-- Native Lidar for Obstacle Avoidance -->
    <sensor name="kinect_v2_lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <topic>/scan</topic>
      <gz_frame_id>base_footprint</gz_frame_id>
      
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.1416</min_angle>
            <max_angle>3.1416</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.15</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.005</stddev>
        </noise>
      </lidar>
    </sensor>

    <!-- RGBD Camera for RTAB-Map and YOLO -->
    <sensor name="kinect_v2" type="rgbd_camera">
      <always_on>true</always_on>
      <update_rate>15.0</update_rate>
      <topic>/camera</topic>
      <gz_frame_id>camera_depth_optical_frame</gz_frame_id>
      <camera name="rgbd_camera">
        <horizontal_fov>1.089</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
        <depth_camera>
          <clip>
            <near>0.1</near>
            <far>8.0</far>
          </clip>
        </depth_camera>
      </camera>
    </sensor>
  </gazebo>

  <!-- Joint state publisher plugin (publishes wheel joint states) -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

</robot>
